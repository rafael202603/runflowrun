{
  "name": "ushuaia-runner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:portable-html": "powershell -ExecutionPolicy Bypass -File ./portable/build-portable-html.ps1",
    "build:portable": "powershell -ExecutionPolicy Bypass -File ./portable/build-portable.ps1",
    "build:pages": "tsc -b && vite build --mode github-pages",
    "preview": "vite preview",
    "serve:dist": "powershell -ExecutionPolicy Bypass -File ./run-local.ps1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
